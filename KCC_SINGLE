# =====================================
# Qwen2.5-VL 3B + 중앙 LLM FULL PIPELINE (수정판 v3)
# 핵심: 모델을 동시에 올리지 않고 순차 로드 → VRAM 절약
# =====================================
import gc
import torch
from PIL import Image
import torch.nn.functional as F
from transformers import AutoProcessor, Qwen2_5_VLForConditionalGeneration, AutoTokenizer, AutoModelForCausalLM

device = "cuda:0" if torch.cuda.is_available() else "cpu"

# =====================================
# 유틸: 모델 언로드 & VRAM 완전 해제
# =====================================
def unload_model(model):
    model.cpu()
    del model
    gc.collect()
    torch.cuda.empty_cache()

# =====================================
# 1️⃣ Entropy 계산
# =====================================
def compute_entropy(scores):
    if not scores:
        return 0.0
    entropies = []
    for step_logits in scores:
        probs = F.softmax(step_logits, dim=-1)
        log_probs = torch.log(probs + 1e-12)
        entropy = -(probs * log_probs).sum(dim=-1)
        entropies.append(entropy.mean().item())
    return sum(entropies) / len(entropies)

# =====================================
# 2️⃣ 이미지 로드 (PIL 리스트, tensor 변환 X)
# =====================================
img1 = Image.open("kitchen.jpg").convert("RGB").resize((224, 224))
img2 = Image.open("livingroom.jpg").convert("RGB").resize((224, 224))
images = [img1, img2]

task = "Friends are arriving in 30 minutes. Prepare the house."
prompt_init = f"""
You see two images: kitchen and living room.

Task: {task}

Give:
- Observations
- Problems
- Plan (max 4)
"""

# =====================================
# 3️⃣ STEP 1: VLM 로드 → 실행 → 즉시 언로드
# =====================================
print(">>> VLM 로드 중...")
vlm_id = "Qwen/Qwen2.5-VL-3B-Instruct"
processor = AutoProcessor.from_pretrained(vlm_id)
vlm_model = Qwen2_5_VLForConditionalGeneration.from_pretrained(
    vlm_id,
    torch_dtype=torch.float16,
).to(device)
vlm_model.eval()

messages = [
    {
        "role": "user",
        "content": [
            {"type": "image", "image": images[0]},
            {"type": "image", "image": images[1]},
            {"type": "text",  "text": prompt_init},
        ],
    }
]
text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
inputs = processor(text=[text], images=images, return_tensors="pt", padding=True).to(device)

with torch.no_grad():
    outputs = vlm_model.generate(
        **inputs,
        max_new_tokens=150,
        return_dict_in_generate=True,
        output_scores=True
    )

generated = outputs.sequences[:, inputs["input_ids"].shape[1]:]
result = processor.batch_decode(generated, skip_special_tokens=True)[0]
scores  = outputs.scores if outputs.scores else []
U = compute_entropy(scores)

print("=== INITIAL PLAN ===")
print(result)
print("Uncertainty:", U)

# VLM 즉시 언로드
unload_model(vlm_model)
del processor, inputs, outputs, generated, scores
gc.collect()
torch.cuda.empty_cache()
print(">>> VLM 언로드 완료\n")

# =====================================
# 4️⃣ STEP 2: LLM 로드 → Human Query + Final Plan → 언로드
# =====================================
print(">>> LLM 로드 중...")
llm_id = "microsoft/Phi-3-mini-4k-instruct"
tokenizer = AutoTokenizer.from_pretrained(llm_id)
llm_model = AutoModelForCausalLM.from_pretrained(
    llm_id,
    torch_dtype=torch.float16,
).to(device)
llm_model.eval()

def run_llm(prompt):
    inputs = tokenizer(prompt, return_tensors="pt").to(device)
    with torch.no_grad():
        outputs = llm_model.generate(**inputs, max_new_tokens=150)
    return tokenizer.decode(outputs[0], skip_special_tokens=True)

# Human Query
if U > 0.5:
    prompt_hq = f"""Task: {task}

Plan:
{result}

Ask one critical question."""
    human_q = run_llm(prompt_hq)
else:
    human_q = "No question needed."

print("\n[Human Query]")
print(human_q)

# Final Plan
final_prompt = f"""Task: {task}

Initial Plan:
{result}

Uncertainty: {U}

Human Input:
{human_q}

Give FINAL PLAN (max 4 steps)"""

final = run_llm(final_prompt)
print("\n=== FINAL PLAN ===")
print(final)

# LLM 언로드
unload_model(llm_model)
print(">>> LLM 언로드 완료")
